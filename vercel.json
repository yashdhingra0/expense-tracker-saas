{
  "version": 2,
  "builds": [
    {
      "src": "app/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "web/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/v1/(.*)",
      "dest": "app/main.py"
    },
    {
      "src": "/tg/(.*)",
      "dest": "app/main.py"
    },
    {
      "src": "/health",
      "dest": "app/main.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "web/$1"
    },
    {
      "src": "/(.*)",
      "dest": "web/index.html"
    }
  ]
}
