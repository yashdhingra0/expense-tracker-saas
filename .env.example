# Copy to .env and fill in. Never commit the real .env.

# --- Database ---------------------------------------------------------------
# Local dev (zero setup):
DATABASE_URL=sqlite:///./expense_saas.db
# Production (managed Postgres — Neon / Supabase / RDS). Example:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/dbname

# --- Security ---------------------------------------------------------------
# Signs session cookies. Generate: python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=dev-only-change-me

# Encrypts stored Telegram bot tokens (stand-in for a cloud KMS in dev).
# Generate: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
TOKEN_ENC_KEY=

# --- Dev conveniences -------------------------------------------------------
# When true, /bots/connect will store a token even if getMe can't be reached
# (useful offline). Set to false in production.
DEV_ALLOW_UNVERIFIED_TOKENS=true

# Public base URL used when registering Telegram webhooks (production).
PUBLIC_BASE_URL=https://api.example.com
